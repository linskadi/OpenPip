{
  "name": "OpenPip",
  "version": "0.1.0",
  "description": "论文智能体系统",
  "runtime": "agent",
  "private_mode": true,
  "default_model": "deepseek/deepseek-chat",
  "project_dir": "papers",
  "roles_dir": ".openpip/role-configs",
  "prompts_dir": ".openpip/role-prompts",
  "knowledge_dir": ".openpip/knowledge",
  "pipelines_dir": ".openpip/pipelines",
  "features": {
    "event_bus": true,
    "knowledge_growth": true,
    "version_management": true,
    "model_router": true,
    "reverse_outline": true,
    "debug_observability": true,
    "visual_progress": true,
    "iterative_review": true,
    "anti_sycophancy": true,
    "fact_verification": true,
    "figure_generation": true,
    "competition_mode": true,
    "iterative_optimization": true,
    "chapter_self_critic": true,
    "contribution_architect": true,
    "adversarial_review": true,
    "literature_synthesis": true,
    "arxiv_search": true,
    "consistency_checker": true,
    "structured_logging": true,
    "tracing": true,
    "academic_compliance": false,
    "venue_adapter": false,
    "output_validator": false,
    "runtime_interface": false,
    "di_container": false,
    "docker_build": false
  },
  "agents": [
    "orchestrator",
    "researcher",
    "planner",
    "writer",
    "coder",
    "reviewer",
    "formatter",
    "code-reviewer",
    "contribution-architect",
    "adversarial-researcher"
  ],
  "pipelines": [
    "lightweight",
    "full-research",
    "full-paper",
    "research-cs",
    "code-review",
    "competition-math-modeling",
    "competition-data-science",
    "competition-general",
    "iterative-optimization"
  ]
}
